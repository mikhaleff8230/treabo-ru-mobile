{
  "expo": {
    "name": "Treabo",
    "slug": "treabo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "treabo",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F5F6F1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ru.sancan.proffi"
    },
    "android": {
      "package": "ru.sancan.proffi",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#F5F6F1"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Treabo использует геолокацию, чтобы показывать задания рядом с вами."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Treabo нужен доступ к фото для аватара, портфолио и файлов в заданиях."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-sqlite"
    ]
  }
}

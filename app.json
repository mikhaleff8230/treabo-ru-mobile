{
  "expo": {
    "name": "Treabo",
    "slug": "treabo",
    "version": "1.0.5",
    "orientation": "portrait",
    "scheme": "treabo",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/treabo-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ru.sancan.proffi",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "ru.sancan.proffi",
      "googleServicesFile": "./google-services.json",
      "versionCode": 9,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Treabo использует геолокацию, чтобы показывать задания рядом с вами."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Treabo нужен доступ к фото для аватара, портфолио и файлов в заданиях."
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#D9F36B",
          "defaultChannel": "messages"
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "d190d995-496b-46e1-9564-a548b3114859"
      }
    },
    "owner": "sancans-team"
  }
}

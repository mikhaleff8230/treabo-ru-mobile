# API base URL without /api suffix.
# Production:
EXPO_PUBLIC_API_URL=https://api.treabo.ru
# Expo Go on a phone must use a reachable host, not 127.0.0.1.
# Local Docker example: EXPO_PUBLIC_API_URL=http://192.168.1.10:8001

# Laravel WebSockets / Proffi realtime chat.
EXPO_PUBLIC_PUSHER_KEY=proffi-local-key
EXPO_PUBLIC_PUSHER_HOST=api.treabo.ru
EXPO_PUBLIC_PUSHER_PORT=443
EXPO_PUBLIC_PUSHER_SCHEME=https

# 0 = real Laravel auth, 1 = local mock auth for UI-only debugging.
EXPO_PUBLIC_SKIP_AUTH=0

# Yandex Maps JavaScript API key.
EXPO_PUBLIC_YANDEX_MAPS_API_KEY=
